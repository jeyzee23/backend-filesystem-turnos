{
  "info": {
    "name": "Turnos - Persistencia FileSystem",
    "description": "Colección de persistencia con archivos JSON y fs.promises.\n\nLevantar el servidor:\n  npm run dev\n\nBase URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "serviceId",
      "value": "1"
    },
    {
      "key": "bookingId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "01 - ServiceManager (CRUD servicios)",
      "item": [
        {
          "name": "Listar servicios",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/services"
          }
        },
        {
          "name": "Crear servicio - Consulta médica",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.payload?.id) {",
                  "  pm.collectionVariables.set('serviceId', String(json.payload.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Consulta médica general\",\n  \"description\": \"Atención médica de primer nivel\",\n  \"duration\": 30,\n  \"price\": 12000,\n  \"category\": \"salud\",\n  \"available\": true\n}"
            },
            "url": "{{baseUrl}}/api/services"
          }
        },
        {
          "name": "Crear servicio - Fisioterapia",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sesión de fisioterapia\",\n  \"description\": \"Rehabilitación y kinesiología\",\n  \"duration\": 45,\n  \"price\": 15000,\n  \"category\": \"rehabilitación\",\n  \"available\": true\n}"
            },
            "url": "{{baseUrl}}/api/services"
          }
        },
        {
          "name": "Obtener servicio por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/services/{{serviceId}}"
          }
        },
        {
          "name": "Actualizar servicio",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 13500,\n  \"available\": false\n}"
            },
            "url": "{{baseUrl}}/api/services/{{serviceId}}"
          }
        },
        {
          "name": "Eliminar servicio",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/services/{{serviceId}}"
          }
        }
      ]
    },
    {
      "name": "02 - BookingManager (CRUD reservas)",
      "item": [
        {
          "name": "Listar reservas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "Crear reserva",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.payload?.id) {",
                  "  pm.collectionVariables.set('bookingId', String(json.payload.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": 1,\n  \"clientName\": \"María López\",\n  \"date\": \"2026-07-20T10:00:00\",\n  \"status\": \"pending\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "Obtener reserva por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Actualizar reserva",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Eliminar reserva",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "03 - ProductManager",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Crear producto - Teclado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Teclado\",\n  \"price\": 25\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        }
      ]
    }
  ]
}
