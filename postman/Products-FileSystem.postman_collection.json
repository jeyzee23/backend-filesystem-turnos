{
  "info": {
    "name": "ProductManager - FileSystem",
    "description": "Colección para ProductManager con persistencia JSON.\n\nLevantar el servidor:\n  npm run dev\n\nBase URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Crear producto - Teclado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Teclado\",\n  \"price\": 25\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        }
      ]
    }
  ]
}
